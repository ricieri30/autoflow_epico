# ─── AutoFlow Epico — exemplo de variaveis de ambiente ───
# Copie para .env e preencha com valores REAIS antes do deploy.
# NUNCA commite o arquivo .env (ja esta no .gitignore).

# Segredo de assinatura dos JWT. Gere com: openssl rand -hex 32
JWT_SECRET=COLOQUE_UM_VALOR_ALEATORIO_AQUI

# Admin inicial (criado no primeiro boot se nao existir)
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin123

# CORS — origens permitidas, separadas por virgula (sem espacos).
# Ex.: https://app.seudominio.com,https://admin.seudominio.com
# Deixe vazio para permitir apenas same-origin (via proxy nginx).
CORS_ORIGINS=

# Banco e fila
MONGO_URL=mongodb://mongo:27017/wa_admin
REDIS_HOST=redis

# Gateway do WhatsApp (interno)
WA_GATEWAY_URL=http://gateway:3333

# Anti-bloqueio (atraso entre envios)
MIN_MESSAGE_DELAY_MS=2000
JITTER_MS=1000

# Textos de aviso de vencimento de assinatura (opcional)
NOTICE_7D=Ola {{nome}}! Sua assinatura vence em 7 dias.
NOTICE_1D=Atencao {{nome}}! Sua assinatura vence amanha.
NOTICE_TODAY=Ola {{nome}}! Sua assinatura expira hoje.

# Diretorio de midias (volume compartilhado)
MEDIA_DIR=/media
